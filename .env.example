# =============================================================================
# Configuração de Ambiente - Controle de Saldo de Banco de Horas
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# Banco de Dados (OBRIGATÓRIO)
# =============================================================================
# Suporta PostgreSQL e MySQL. O tipo é detectado automaticamente pela URL.
#
# PostgreSQL:
#   DATABASE_URL=postgresql://usuario:senha@host:5432/controle_ponto
#
# MySQL:
#   DATABASE_URL=mysql://usuario:senha@host:3306/controle_ponto
DATABASE_URL=

# =============================================================================
# Autenticação JWT (OBRIGATÓRIO)
# =============================================================================
# Chave secreta usada para assinar os tokens de sessão JWT.
# Gere uma chave forte com: openssl rand -base64 32
JWT_SECRET=

# =============================================================================
# OAuth Manus (OBRIGATÓRIO)
# =============================================================================
# ID do aplicativo no Manus
VITE_APP_ID=

# URL do servidor de autenticação OAuth
OAUTH_SERVER_URL=

# URL do portal OAuth (usado no frontend para redirecionar login)
VITE_OAUTH_PORTAL_URL=

# Open ID do proprietário do projeto (admin)
OWNER_OPEN_ID=

# =============================================================================
# Manus Forge API (Serviços Internos)
# =============================================================================
# URL base da API Forge
BUILT_IN_FORGE_API_URL=

# Chave de API Forge
BUILT_IN_FORGE_API_KEY=

# URL e chave para o frontend (usado no proxy do Google Maps)
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# =============================================================================
# Analytics (OPCIONAL)
# =============================================================================
# Endpoint e ID do website para analytics (Umami)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# =============================================================================
# Configurações da Aplicação
# =============================================================================
# Ambiente: production (padrão) ou development
NODE_ENV=production

# Porta em que o servidor será executado (padrão: 3000)
PORT=3000