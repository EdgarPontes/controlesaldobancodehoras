# =============================================================================
# Controle de Ponto - Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e ajuste conforme seu ambiente
# =============================================================================

# Banco de dados externo (PostgreSQL ou MySQL)
# PostgreSQL: DATABASE_URL=postgresql://usuario:senha@host:5432/controle_ponto
# MySQL: DATABASE_URL=mysql://usuario:senha@host:3306/controle_ponto
DATABASE_URL=

# Autenticação (gere uma chave segura)
JWT_SECRET=

# Aplicacao
NODE_ENV=production
PORT=3000
